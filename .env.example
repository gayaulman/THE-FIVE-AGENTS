# THE FIVE AGENTS — environment variables template
# Copy this file to `.env` and fill in real values. `.env` is gitignored.

# Anthropic / Claude API key — required for calling Claude programmatically.
# Get one at https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# GitHub Personal Access Token — used for git push and gh CLI authentication.
# Create at https://github.com/settings/tokens
GITHUB_TOKEN=your-github-token-here

# OpenAI API key — required for the gpt-image-gen skill (gpt-image-2 model).
# Used by Yuval (image designer) to call the OpenAI Images API.
# Get one at https://platform.openai.com/api-keys
OPENAI_API_KEY=your-openai-api-key-here
